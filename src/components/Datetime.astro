---
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import IconCalendar from "@/assets/icons/IconCalendar.svg";
import { SITE } from "@/config";

dayjs.extend(utc);
dayjs.extend(timezone);

type Props = {
  class?: string;
  size?: "sm" | "lg";
  pubDatetime: string | Date;
  timezone?: string;
  modDatetime?: string | Date | null;
  showPubtime?: boolean;
  showModtime?: boolean;
};

const {
  pubDatetime,
  modDatetime,
  size = "sm",
  class: className = "",
  timezone: postTimezone,
  showPubtime = true,
  showModtime = true,
} = Astro.props;

/* ========== Formatted Datetime ========== */
const pubTime = dayjs(pubDatetime).tz(postTimezone || SITE.timezone);
const formattedPubDate = pubTime.format("YYYY/MM/DD"); // e.g., "2026-02-19"

const isModified = modDatetime && dayjs(modDatetime).isAfter(pubDatetime);

const modTime = isModified
  ? dayjs(modDatetime).tz(postTimezone || SITE.timezone)
  : null;

const formattedModDate = modTime ? modTime.format("YYYY/MM/DD") : "";
---

<div class:list={["flex items-center gap-x-1 opacity-80", className]}>
  <IconCalendar
    class:list={[
      "inline-block size-6 min-w-5.5",
      { "scale-90": size === "sm" },
    ]}
  />
  <div>
    {
      showPubtime && (
        <>
          <span class:list={["text-sm", { "sm:text-base": size === "lg" }]}>
            Pub:
          </span>
          <time
            class:list={["text-sm", { "sm:text-base": size === "lg" }]}
            datetime={pubTime.toISOString()}
            title={pubTime.format("D MMMM YYYY")}
          >
            {formattedPubDate}
          </time>
        </>
      )
    }

    {
      isModified && modTime && showModtime && (
        <>
          <p class="text-sm">|</p>

          <p
            class:list={[
              "text-sm text-amber-700 dark:text-amber-400",
              { "sm:text-base": size === "lg" },
            ]}
          >
            Upd:
          </p>

          <time
            class:list={[
              "text-sm text-amber-800 dark:text-amber-300",
              { "sm:text-base": size === "lg" },
            ]}
            datetime={modTime.toISOString()}
            title={modTime.format("D MMMM YYYY")}
          >
            {formattedModDate}
          </time>
        </>
      )
    }
  </div>
</div>
