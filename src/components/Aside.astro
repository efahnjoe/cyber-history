---
type Props = {
  class?: string;
  as?: "aside" | "nav" | "div" | "section";
  position?: "left" | "right";
};

const { class: className, as: Tag = "aside", position } = Astro.props;
---

<Tag
  class:list={[
    "max-h-full max-w-full overflow-y-auto",
    position === "left" && "order-first",
    position === "right" && "order-last",
    className,
  ]}
>
  <slot />
</Tag>
